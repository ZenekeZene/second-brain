# Telegram bot
TELEGRAM_BOT_TOKEN=        # from @BotFather
TELEGRAM_ALLOWED_USER_ID=  # your numeric user ID (find via @userinfobot)

# OpenAI (voice transcription + image analysis — only needed for the Telegram bot)
OPENAI_API_KEY=

# Reactive compilation thresholds (optional — these are the defaults)
REACTIVE_THRESHOLD_ITEMS=5   # compile after N pending items
REACTIVE_THRESHOLD_HOURS=48  # compile if pending and no compile in X hours
