{
  "name": "second-brain",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-maintained personal wiki. Ingest URLs, notes, bookmarks, voice memos and images — an LLM compiles them into an interconnected wiki.",
  "keywords": [
    "second-brain",
    "personal-wiki",
    "llm",
    "ai",
    "knowledge-management",
    "obsidian",
    "zettelkasten",
    "claude",
    "telegram-bot",
    "markdown"
  ],
  "author": "Zeneke",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZenekeZene/second-brain.git"
  },
  "homepage": "https://github.com/ZenekeZene/second-brain#readme",
  "bugs": {
    "url": "https://github.com/ZenekeZene/second-brain/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node bin/status.mjs --full",
    "test": "node --test test/*.test.mjs",
    "ingest": "node bin/ingest.mjs",
    "compile": "node bin/compile.mjs",
    "search": "node bin/search.mjs",
    "status": "node bin/status.mjs",
    "bot": "node bin/telegram-bot.mjs",
    "reactive": "node bin/reactive.mjs",
    "digest": "node bin/daily-digest.mjs",
    "route": "node bin/route.mjs",
    "sync-x": "node bin/sync-x.mjs",
    "sync-x:full": "node bin/sync-x.mjs --full",
    "sync-x:classify": "node bin/sync-x.mjs --classify"
  },
  "dependencies": {
    "openai": "^6.33.0",
    "telegraf": "^4.16.3",
    "turndown": "^7.2.0"
  }
}
